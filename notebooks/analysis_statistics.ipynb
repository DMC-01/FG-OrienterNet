    "    \"print(regional_stats)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Heatmap of mean distance error by region\\n\",\n",
    "    \"pivot_dist = df.pivot_table(values='distance_m', index='lat_bin', columns='lon_bin', aggfunc='mean')\\n\",\n",
    "    \"pivot_yaw = df.pivot_table(values='yaw_error_abs', index='lat_bin', columns='lon_bin', aggfunc='mean')\\n\",\n",
    "    \"\\n\",\n",
