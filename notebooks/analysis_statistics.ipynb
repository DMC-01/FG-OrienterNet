    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Create distance error choropleth\\n\",\n",
    "    \"m_dist = folium.Map(\\n\",\n",
    "    \"    location=[map_center_lat, map_center_lon],\\n\",\n",
    "    \"    zoom_start=12,\\n\",\n",
    "    \"    tiles='OpenStreetMap'\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Normalize distance errors for color scale (only cells with data)\\n\",\n",
    "    \"max_dist = s2_stats[s2_stats['count'] > 0]['dist_mean'].max()\\n\",\n",
    "    \"min_dist = s2_stats[s2_stats['count'] > 0]['dist_mean'].min()\\n\",\n",
    "    \"\\n\",\n",
    "    \"for idx, row in s2_stats.iterrows():\\n\",\n",
    "    \"    if row['count'] > 0:  # Only draw cells with data\\n\",\n",
    "    \"        # Normalize value to [0, 1]\\n\",\n",
    "    \"        norm_value = (row['dist_mean'] - min_dist) / (max_dist - min_dist) if max_dist > min_dist else 0\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        # Color map: green (low) -> yellow -> orange -> red (high)\\n\",\n",
    "    \"        if norm_value < 0.25:\\n\",\n",
    "    \"            color = '#2ecc71'  # Green\\n\",\n",
    "    \"        elif norm_value < 0.5:\\n\",\n",
    "    \"            color = '#f1c40f'  # Yellow\\n\",\n",
    "    \"        elif norm_value < 0.75:\\n\",\n",
    "    \"            color = '#ff9500'  # Orange\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            color = '#e74c3c'  # Red\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        # Convert geometry to GeoJSON\\n\",\n",
    "    \"        if row.geometry.geom_type == 'Polygon':\\n\",\n",
    "    \"            folium.GeoJson(\\n\",\n",
    "    \"                row.geometry.__geo_interface__,\\n\",\n",
    "    \"                style_function=lambda x, color=color: {\\n\",\n",
    "    \"                    'fillColor': color,\\n\",\n",
    "    \"                    'color': 'black',\\n\",\n",
    "    \"                    'weight': 0.5,\\n\",\n",
    "    \"                    'fillOpacity': 0.7\\n\",\n",
    "    \"                },\\n\",\n",
    "    \"                popup=folium.Popup(\\n\",\n",
    "    \"                    f\\\"<b>Mean Distance Error:</b> {row['dist_mean']:.2f} m<br>\\\"\\n\",\n",
    "    \"                    f\\\"<b>Std Dev:</b> {row['dist_std']:.2f} m<br>\\\"\\n\",\n",
    "    \"                    f\\\"<b>Predictions:</b> {int(row['count'])}<br>\\\"\\n\",\n",
    "    \"                    f\\\"<b>Mean Yaw Error:</b> {row['yaw_mean']:.2f}°\\\",\\n\",\n",
    "    \"                    max_width=250\\n\",\n",
    "    \"                )\\n\",\n",
    "    \"            ).add_to(m_dist)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Add legend\\n\",\n",
    "    \"legend_html = '''\\n\",\n",
    "    \"<div style=\\\"position: fixed; \\n\",\n",
    "    \"     bottom: 50px; right: 50px; width: 220px; height: 200px; \\n\",\n",
    "    \"     background-color: white; border:2px solid grey; z-index:9999; font-size:14px;\\n\",\n",
    "    \"     padding: 10px\\\">\\n\",\n",
    "    \"     <p><b>Mean Distance Error (m)</b></p>\\n\",\n",
    "    \"     <p><i class=\\\"fa fa-square\\\" style=\\\"color:#2ecc71\\\"></i> Low error</p>\\n\",\n",
    "    \"     <p><i class=\\\"fa fa-square\\\" style=\\\"color:#f1c40f\\\"></i> Low-medium</p>\\n\",\n",
    "    \"     <p><i class=\\\"fa fa-square\\\" style=\\\"color:#ff9500\\\"></i> Medium-high</p>\\n\",\n",
    "    \"     <p><i class=\\\"fa fa-square\\\" style=\\\"color:#e74c3c\\\"></i> High error</p>\\n\",\n",
    "    \"     <p><b>Range:</b> {:.2f} - {:.2f} m</p>\\n\",\n",
    "    \"</div>\\n\",\n",
    "    \"'''.format(min_dist, max_dist)\\n\",\n",
    "    \"m_dist.get_root().html.add_child(folium.Element(legend_html))\\n\",\n",
    "    \"\\n\",\n",
    "    \"m_dist.save('map_distance_errors_per_cell.html')\\n\",\n",
    "    \"print(\\\"✓ Map saved as 'map_distance_errors_per_cell.html'\\\")\\n\",\n",
    "    \"m_dist\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
