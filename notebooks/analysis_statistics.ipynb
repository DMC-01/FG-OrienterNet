    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"correlation = df['distance_m'].corr(df['yaw_error_abs'])\\n\",\n",
    "    \"print(f\\\"Correlation between Distance and Yaw Error: {correlation:.4f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(10, 6))\\n\",\n",
    "    \"ax.scatter(df['distance_m'], df['yaw_error_abs'], alpha=0.5, s=20)\\n\",\n",
