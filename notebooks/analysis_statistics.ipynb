    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Create 5x5 degree latitude/longitude bins\\n\",\n",
    "    \"df['lat_bin'] = pd.cut(df['true_lat'], bins=6)\\n\",\n",
    "    \"df['lon_bin'] = pd.cut(df['true_lon'], bins=6)\\n\",\n",
    "    \"\\n\",\n",
