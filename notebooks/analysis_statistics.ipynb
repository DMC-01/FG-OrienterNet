    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# OrienterNet: Prediction Statistics & Analysis\\n\",\n",
    "    \"### Statistics per cell with S2 grid visualization\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 1: Imports & Setup\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import geopandas as gpd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"import folium\\n\",\n",
    "    \"from folium import plugins\\n\",\n",
    "    \"from scipy.spatial.distance import cdist\\n\",\n",
    "    \"from scipy import stats\\n\",\n",
    "    \"import warnings\\n\",\n",
    "    \"warnings.filterwarnings('ignore')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Set style\\n\",\n",
    "    \"sns.set_style('whitegrid')\\n\",\n",
    "    \"plt.rcParams['figure.figsize'] = (14, 8)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"✓ All imports successful\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 2: Load Data\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Load results\\n\",\n",
    "    \"results_file = 'orienternet_results.csv'\\n\",\n",
    "    \"df = pd.read_csv(results_file)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Loaded {len(df)} predictions\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nColumns: {df.columns.tolist()}\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nFirst rows:\\\")\\n\",\n",
    "    \"print(df.head())\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Load S2 cells\\n\",\n",
    "    \"s2_cells = gpd.read_file('data/cells/bern_13.gpkg')\\n\",\n",
    "    \"print(f\\\"\\\\nLoaded {len(s2_cells)} S2 cells\\\")\\n\",\n",
    "    \"print(f\\\"S2 cells CRS: {s2_cells.crs}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 3: Calculate Geodetic Distances (Haversine - WGS84)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from math import radians, cos, sin, asin, sqrt\\n\",\n",
    "    \"\\n\",\n",
    "    \"def haversine(lon1, lat1, lon2, lat2):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Calculate great circle distance between two points \\n\",\n",
    "    \"    on the earth (specified in decimal degrees)\\n\",\n",
    "    \"    Returns distance in meters\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    # Convert decimal degrees to radians \\n\",\n",
    "    \"    lon1, lat1, lon2, lat2 = map(radians, [lon1, lat1, lon2, lat2])\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # Haversine formula \\n\",\n",
    "    \"    dlon = lon2 - lon1 \\n\",\n",
    "    \"    dlat = lat2 - lat1 \\n\",\n",
    "    \"    a = sin(dlat/2)**2 + cos(lat1) * cos(lat2) * sin(dlon/2)**2\\n\",\n",
    "    \"    c = 2 * asin(sqrt(a)) \\n\",\n",
    "    \"    r = 6371000  # Radius of earth in meters\\n\",\n",
    "    \"    return c * r\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Calculate distances\\n\",\n",
    "    \"df['distance_m'] = df.apply(\\n\",\n",
    "    \"    lambda row: haversine(\\n\",\n",
    "    \"        row['pred_lon'], row['pred_lat'],\\n\",\n",
    "    \"        row['true_lon'], row['true_lat']\\n\",\n",
    "    \"    ), axis=1\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Distance Statistics (meters):\\\")\\n\",\n",
    "    \"print(df['distance_m'].describe())\\n\",\n",
    "    \"print(f\\\"\\\\nMedian distance: {df['distance_m'].median():.2f} m\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 4: Calculate Yaw Errors\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"def normalize_angle(angle):\\n\",\n",
    "    \"    \\\"\\\"\\\"Normalize angle to [-180, 180]\\\"\\\"\\\"\\n\",\n",
    "    \"    while angle > 180:\\n\",\n",
    "    \"        angle -= 360\\n\",\n",
    "    \"    while angle < -180:\\n\",\n",
    "    \"        angle += 360\\n\",\n",
    "    \"    return angle\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Calculate yaw error (signed and absolute)\\n\",\n",
    "    \"df['yaw_error_signed'] = df.apply(\\n\",\n",
    "    \"    lambda row: normalize_angle(row['pred_yaw'] - row['true_yaw']),\\n\",\n",
    "    \"    axis=1\\n\",\n",
    "    \")\\n\",\n",
    "    \"df['yaw_error_abs'] = df['yaw_error_signed'].abs()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Yaw Error Statistics (degrees):\\\")\\n\",\n",
    "    \"print(f\\\"  Min: {df['yaw_error_abs'].min():.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Max: {df['yaw_error_abs'].max():.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Mean: {df['yaw_error_abs'].mean():.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Median: {df['yaw_error_abs'].median():.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Std: {df['yaw_error_abs'].std():.2f}°\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 5: Loss Functions\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Calculate different loss metrics\\n\",\n",
    "    \"mae_distance = df['distance_m'].mean()\\n\",\n",
    "    \"rmse_distance = np.sqrt((df['distance_m']**2).mean())\\n\",\n",
    "    \"mae_yaw = df['yaw_error_abs'].mean()\\n\",\n",
    "    \"rmse_yaw = np.sqrt((df['yaw_error_abs']**2).mean())\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Normalized combined loss (equal weight)\\n\",\n",
    "    \"# Normalize by median values for fair comparison\\n\",\n",
    "    \"median_dist = df['distance_m'].median()\\n\",\n",
    "    \"median_yaw = df['yaw_error_abs'].median()\\n\",\n",
    "    \"\\n\",\n",
    "    \"df['loss_combined'] = (\\n\",\n",
    "    \"    (df['distance_m'] / median_dist) + \\n\",\n",
    "    \"    (df['yaw_error_abs'] / median_yaw)\\n\",\n",
    "    \") / 2\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Loss Metrics:\\\")\\n\",\n",
    "    \"print(f\\\"  Distance MAE: {mae_distance:.2f} m\\\")\\n\",\n",
    "    \"print(f\\\"  Distance RMSE: {rmse_distance:.2f} m\\\")\\n\",\n",
    "    \"print(f\\\"  Yaw MAE: {mae_yaw:.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Yaw RMSE: {rmse_yaw:.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Combined Loss Mean: {df['loss_combined'].mean():.4f}\\\")\\n\",\n",
    "    \"print(f\\\"  Combined Loss Median: {df['loss_combined'].median():.4f}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 6: Distance Error Histogram (Linear)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 5))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Linear scale\\n\",\n",
    "    \"ax1.hist(df['distance_m'], bins=50, color='steelblue', edgecolor='black', alpha=0.7)\\n\",\n",
    "    \"ax1.axvline(df['distance_m'].mean(), color='red', linestyle='--', linewidth=2, label=f'Mean: {df[\\\"distance_m\\\"].mean():.1f}m')\\n\",\n",
    "    \"ax1.axvline(df['distance_m'].median(), color='green', linestyle='--', linewidth=2, label=f'Median: {df[\\\"distance_m\\\"].median():.1f}m')\\n\",\n",
    "    \"ax1.set_xlabel('Distance Error (meters)')\\n\",\n",
    "    \"ax1.set_ylabel('Frequency')\\n\",\n",
    "    \"ax1.set_title('Distance Error Distribution (Linear Scale)')\\n\",\n",
    "    \"ax1.legend()\\n\",\n",
    "    \"ax1.grid(True, alpha=0.3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Log scale\\n\",\n",
    "    \"ax2.hist(df['distance_m'], bins=50, color='steelblue', edgecolor='black', alpha=0.7)\\n\",\n",
    "    \"ax2.set_yscale('log')\\n\",\n",
    "    \"ax2.axvline(df['distance_m'].mean(), color='red', linestyle='--', linewidth=2, label=f'Mean: {df[\\\"distance_m\\\"].mean():.1f}m')\\n\",\n",
    "    \"ax2.axvline(df['distance_m'].median(), color='green', linestyle='--', linewidth=2, label=f'Median: {df[\\\"distance_m\\\"].median():.1f}m')\\n\",\n",
    "    \"ax2.set_xlabel('Distance Error (meters)')\\n\",\n",
    "    \"ax2.set_ylabel('Frequency (log scale)')\\n\",\n",
    "    \"ax2.set_title('Distance Error Distribution (Log Scale)')\\n\",\n",
    "    \"ax2.legend()\\n\",\n",
    "    \"ax2.grid(True, alpha=0.3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 7: Yaw Error Histogram\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 5))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Signed yaw errors\\n\",\n",
    "    \"ax1.hist(df['yaw_error_signed'], bins=50, color='coral', edgecolor='black', alpha=0.7)\\n\",\n",
    "    \"ax1.axvline(df['yaw_error_signed'].mean(), color='red', linestyle='--', linewidth=2, label=f'Mean: {df[\\\"yaw_error_signed\\\"].mean():.1f}°')\\n\",\n",
    "    \"ax1.axvline(0, color='black', linestyle='-', linewidth=1, alpha=0.5)\\n\",\n",
    "    \"ax1.set_xlabel('Yaw Error Signed (degrees)')\\n\",\n",
    "    \"ax1.set_ylabel('Frequency')\\n\",\n",
    "    \"ax1.set_title('Signed Yaw Error Distribution')\\n\",\n",
    "    \"ax1.legend()\\n\",\n",
    "    \"ax1.grid(True, alpha=0.3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Absolute yaw errors\\n\",\n",
    "    \"ax2.hist(df['yaw_error_abs'], bins=50, color='skyblue', edgecolor='black', alpha=0.7)\\n\",\n",
    "    \"ax2.axvline(df['yaw_error_abs'].mean(), color='red', linestyle='--', linewidth=2, label=f'Mean: {df[\\\"yaw_error_abs\\\"].mean():.1f}°')\\n\",\n",
    "    \"ax2.axvline(df['yaw_error_abs'].median(), color='green', linestyle='--', linewidth=2, label=f'Median: {df[\\\"yaw_error_abs\\\"].median():.1f}°')\\n\",\n",
    "    \"ax2.set_xlabel('Yaw Error Absolute (degrees)')\\n\",\n",
    "    \"ax2.set_ylabel('Frequency')\\n\",\n",
    "    \"ax2.set_title('Absolute Yaw Error Distribution')\\n\",\n",
    "    \"ax2.legend()\\n\",\n",
    "    \"ax2.grid(True, alpha=0.3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 8: Percentile Analysis\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"percentiles = [50, 75, 90, 95, 99]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Distance Error Percentiles:\\\")\\n\",\n",
    "    \"for p in percentiles:\\n\",\n",
    "    \"    val = np.percentile(df['distance_m'], p)\\n\",\n",
    "    \"    print(f\\\"  {p}th percentile: {val:.2f} m\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nYaw Error Percentiles (absolute):\\\")\\n\",\n",
    "    \"for p in percentiles:\\n\",\n",
    "    \"    val = np.percentile(df['yaw_error_abs'], p)\\n\",\n",
    "    \"    print(f\\\"  {p}th percentile: {val:.2f}°\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Create visualization\\n\",\n",
    "    \"fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\\n\",\n",
    "    \"\\n\",\n",
    "    \"perc_vals_dist = [np.percentile(df['distance_m'], p) for p in percentiles]\\n\",\n",
    "    \"ax1.bar([str(p) for p in percentiles], perc_vals_dist, color='steelblue')\\n\",\n",
    "    \"ax1.set_xlabel('Percentile')\\n\",\n",
    "    \"ax1.set_ylabel('Distance (meters)')\\n\",\n",
    "    \"ax1.set_title('Distance Error Percentiles')\\n\",\n",
    "    \"ax1.grid(True, alpha=0.3, axis='y')\\n\",\n",
    "    \"\\n\",\n",
    "    \"perc_vals_yaw = [np.percentile(df['yaw_error_abs'], p) for p in percentiles]\\n\",\n",
    "    \"ax2.bar([str(p) for p in percentiles], perc_vals_yaw, color='coral')\\n\",\n",
    "    \"ax2.set_xlabel('Percentile')\\n\",\n",
    "    \"ax2.set_ylabel('Yaw Error (degrees)')\\n\",\n",
    "    \"ax2.set_title('Yaw Error Percentiles')\\n\",\n",
    "    \"ax2.grid(True, alpha=0.3, axis='y')\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 9: Cumulative Distribution Function (CDF)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": {\"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Distance CDF\\n\",\n",
    "    \"sorted_dist = np.sort(df['distance_m'])\\n\",\n",
    "    \"cdf_dist = np.arange(1, len(sorted_dist)+1) / len(sorted_dist)\\n\",\n",
    "    \"ax1.plot(sorted_dist, cdf_dist, linewidth=2, color='steelblue')\\n\",\n",
    "    \"ax1.set_xlabel('Distance Error (meters)')\\n\",\n",
    "    \"ax1.set_ylabel('Cumulative Probability')\\n\",\n",
    "    \"ax1.set_title('Distance Error CDF')\\n\",\n",
    "    \"ax1.grid(True, alpha=0.3)\\n\",\n",
    "    \"ax1.axhline(0.5, color='red', linestyle='--', alpha=0.5, label='50%')\\n\",\n",
    "    \"ax1.axhline(0.9, color='orange', linestyle='--', alpha=0.5, label='90%')\\n\",\n",
    "    \"ax1.legend()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Yaw Error CDF\\n\",\n",
    "    \"sorted_yaw = np.sort(df['yaw_error_abs'])\\n\",\n",
    "    \"cdf_yaw = np.arange(1, len(sorted_yaw)+1) / len(sorted_yaw)\\n\",\n",
    "    \"ax2.plot(sorted_yaw, cdf_yaw, linewidth=2, color='coral')\\n\",\n",
    "    \"ax2.set_xlabel('Yaw Error (degrees)')\\n\",\n",
    "    \"ax2.set_ylabel('Cumulative Probability')\\n\",\n",
    "    \"ax2.set_title('Yaw Error CDF')\\n\",\n",
    "    \"ax2.grid(True, alpha=0.3)\\n\",\n",
    "    \"ax2.axhline(0.5, color='red', linestyle='--', alpha=0.5, label='50%')\\n\",\n",
    "    \"ax2.axhline(0.9, color='orange', linestyle='--', alpha=0.5, label='90%')\\n\",\n",
    "    \"ax2.legend()\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 10: Statistical Summary\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"=\\\"*60)\\n\",\n",
    "    \"print(\\\"DISTANCE ERROR STATISTICS (meters)\\\")\\n\",\n",
    "    \"print(\\\"=\\\"*60)\\n\",\n",
    "    \"print(f\\\"  Count: {len(df)}\\\")\\n\",\n",
    "    \"print(f\\\"  Mean: {df['distance_m'].mean():.2f} m\\\")\\n\",\n",
    "    \"print(f\\\"  Median: {df['distance_m'].median():.2f} m\\\")\\n\",\n",
    "    \"print(f\\\"  Std Dev: {df['distance_m'].std():.2f} m\\\")\\n\",\n",
    "    \"print(f\\\"  Min: {df['distance_m'].min():.2f} m\\\")\\n\",\n",
    "    \"print(f\\\"  Max: {df['distance_m'].max():.2f} m\\\")\\n\",\n",
    "    \"print(f\\\"  Skewness: {stats.skew(df['distance_m']):.4f}\\\")\\n\",\n",
    "    \"print(f\\\"  Kurtosis: {stats.kurtosis(df['distance_m']):.4f}\\\")\\n\",\n",
    "    \"print(f\\\"  Q1 (25%): {df['distance_m'].quantile(0.25):.2f} m\\\")\\n\",\n",
    "    \"print(f\\\"  Q3 (75%): {df['distance_m'].quantile(0.75):.2f} m\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n\\\" + \\\"=\\\"*60)\\n\",\n",
    "    \"print(\\\"YAW ERROR STATISTICS (degrees)\\\")\\n\",\n",
    "    \"print(\\\"=\\\"*60)\\n\",\n",
    "    \"print(f\\\"  Count: {len(df)}\\\")\\n\",\n",
    "    \"print(f\\\"  Mean: {df['yaw_error_abs'].mean():.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Median: {df['yaw_error_abs'].median():.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Std Dev: {df['yaw_error_abs'].std():.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Min: {df['yaw_error_abs'].min():.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Max: {df['yaw_error_abs'].max():.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Skewness: {stats.skew(df['yaw_error_abs']):.4f}\\\")\\n\",\n",
    "    \"print(f\\\"  Kurtosis: {stats.kurtosis(df['yaw_error_abs']):.4f}\\\")\\n\",\n",
    "    \"print(f\\\"  Q1 (25%): {df['yaw_error_abs'].quantile(0.25):.2f}°\\\")\\n\",\n",
    "    \"print(f\\\"  Q3 (75%): {df['yaw_error_abs'].quantile(0.75):.2f}°\\\")\"\n",
