    "    \"    elif dist < dist_threshold * 1.5 and yaw < yaw_threshold * 1.5:\\n\",\n",
    "    \"        return 'Good'\\n\",\n",
    "    \"    elif dist < dist_threshold * 2.5 or yaw < yaw_threshold * 2.5:\\n\",\n",
    "    \"        return 'Acceptable'\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        return 'Poor'\\n\",\n",
    "    \"\\n\",\n",
    "    \"df['error_category'] = df.apply(lambda x: categorize_error(x['distance_m'], x['yaw_error_abs']), axis=1)\\n\",\n",
    "    \"\\n\",\n",
