    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 12: Map Center Calculation\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": {\"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Calculate map center from S2 cells\\n\",\n",
    "    \"s2_bounds = s2_cells.total_bounds  # (minx, miny, maxx, maxy)\\n\",\n",
    "    \"map_center_lat = (s2_bounds[1] + s2_bounds[3]) / 2\\n\",\n",
    "    \"map_center_lon = (s2_bounds[0] + s2_bounds[2]) / 2\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Map Center: ({map_center_lat:.4f}, {map_center_lon:.4f})\\\")\\n\",\n",
    "    \"print(f\\\"Bounds: {s2_bounds}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 13: S2 Cell Visualization - Mean Errors per Cell (Distance & Yaw)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from shapely.geometry import Point\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Ensure DataFrames are in the same CRS\\n\",\n",
    "    \"if s2_cells.crs != 'EPSG:4326':\\n\",\n",
    "    \"    s2_cells = s2_cells.to_crs('EPSG:4326')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Create GeoDataFrame for predictions\\n\",\n",
    "    \"geometry = [Point(xy) for xy in zip(df['pred_lon'], df['pred_lat'])]\\n\",\n",
    "    \"gdf = gpd.GeoDataFrame(df, geometry=geometry, crs='EPSG:4326')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Spatial join to find which S2 cell each prediction belongs to\\n\",\n",
    "    \"points_in_cells = gpd.sjoin(gdf, s2_cells, how='left', predicate='within')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Calculate mean errors per S2 cell\\n\",\n",
    "    \"cell_stats = points_in_cells.groupby('index_right').agg({\\n\",\n",
    "    \"    'distance_m': ['mean', 'std', 'count'],\\n\",\n",
    "    \"    'yaw_error_abs': ['mean', 'std'],\\n\",\n",
    "    \"    'yaw_error_signed': 'mean'\\n\",\n",
    "    \"}).reset_index()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Flatten column names\\n\",\n",
    "    \"cell_stats.columns = ['cell_idx', 'dist_mean', 'dist_std', 'count', 'yaw_mean', 'yaw_std', 'yaw_signed_mean']\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Merge back to get geometry\\n\",\n",
    "    \"s2_stats = s2_cells.reset_index().rename(columns={'index': 'cell_idx'})\\n\",\n",
    "    \"s2_stats = s2_stats.merge(cell_stats, on='cell_idx', how='left')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Fill NaN (cells with no predictions) with 0 for visualization\\n\",\n",
    "    \"s2_stats['dist_mean'] = s2_stats['dist_mean'].fillna(0)\\n\",\n",
    "    \"s2_stats['yaw_mean'] = s2_stats['yaw_mean'].fillna(0)\\n\",\n",
    "    \"s2_stats['count'] = s2_stats['count'].fillna(0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Total S2 cells: {len(s2_stats)}\\\")\\n\",\n",
    "    \"print(f\\\"Cells with predictions: {(s2_stats['count'] > 0).sum()}\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nMean distance error across cells: {s2_stats[s2_stats['count'] > 0]['dist_mean'].mean():.2f} m\\\")\\n\",\n",
    "    \"print(f\\\"Mean yaw error across cells: {s2_stats[s2_stats['count'] > 0]['yaw_mean'].mean():.2f}°\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 14: Choropleth Map - Distance Errors per Cell\"\n",
